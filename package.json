{
  "name": "coffee-2048",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev -H 0.0.0.0",
    "dev:clean": "npm run clean && next dev -H 0.0.0.0",
    "dev:safe": "npm run check:tw && npm run dev:clean",
    "dev:guard": "node scripts/dev-guard.js",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "build:safe": "npm run check:tw && npm run build:clean",
    "start": "next start",
    "lint": "next lint",
    "check:tw": "node scripts/check-tailwind-risk.js"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
