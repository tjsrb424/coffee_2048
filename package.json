{
  "name": "coffee-2048",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "node scripts/dev-guard.js",
    "dev:clean": "npm run clean && next dev -H 0.0.0.0",
    "dev:safe": "npm run check:tw && npm run dev:clean",
    "dev:guard": "node scripts/dev-guard.js",
    "build": "next build",
    "build:export": "node scripts/build-static-export.mjs",
    "build:clean": "npm run clean && next build",
    "build:safe": "npm run check:tw && npm run build:clean",
    "start": "next start",
    "lint": "eslint .",
    "check:tw": "node scripts/check-tailwind-risk.js",
    "typecheck": "tsc --noEmit",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:headed": "playwright test --headed",
    "test:visual:ui": "playwright test --ui",
    "test:visual:report": "playwright show-report",
    "assets:trim-lobby-title": "node scripts/trim-lobby-title-png.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
